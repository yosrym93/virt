# Large binary disk images
common/base_imgs/*
!common/base_imgs/.keep
common/imgs/

# Bundled local QEMU binaries and firmware
common/qemu/*

# Runtime state and Python cache
__pycache__/
*.pyc

# Prebuilt and test binary directories
common/bin/*
!common/bin/.keep
common/tests/*
!common/tests/.keep

# Generated SSH test identities
common/ssh/*
!common/ssh/.keep

# Runtime-generated symlink
common/share/
